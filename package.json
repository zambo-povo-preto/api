    "@prisma/client": "^7.8.0",
    "hono": "^4.12.9",
    "serverless-crypto-utils": "^2.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@cloudflare/workers-types": "^4.20260317.1",
    "prisma": "^7.8.0",
    "wrangler": "^4.4.0"
  }
}
